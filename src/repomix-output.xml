              Vezi Istoric
            </Button>
          </Link>
        </div>
      </motion.div>

      {isLoadingRequests ? (
        <div className="flex flex-col items-center justify-center py-16">
          <Loader2 className="w-10 h-10 animate-spin text-primary-400 mb-4" />
          <span className="text-lg text-primary-500">Se încarcă cererile...</span>
