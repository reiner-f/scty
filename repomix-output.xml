    description: db.description || "",
  };
}

export async function fetchServices(): Promise<Service[]> {
  const { data, error } = await supabase
    .from("services")
    .select("*")
    .order("name");

  if (error) {
    console.error("Error fetching services:", error);
    throw error;
  }

  return (data || []).map(mapDbServiceToService);
}
