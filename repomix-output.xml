type TabType = 'cereri' | 'utilizatori' | 'primarii' | 'furnizori';
type ModalAction = 'detail' | 'editUser' | 'deleteUser' | 'password' | 'addMun' | 'editMun' | 'addProv' | 'editProv' | null;

