// ============================================================================
// COMPONENTE FORMULARE IZOLATE (Previn re-randarea globală și pierderea focusului)
// ============================================================================

function FormChangePassword({ user, onComplete, onCancel }: { user: AdminUserView, onComplete: () => void, onCancel: () => void }) {
  const [pass, setPass] = useState("");
  const [loading, setLoading] = useState(false);
  const { notifySuccess, notifyError } = useApp();

  const submit = async (e: React.FormEvent) => {
    e.preventDefault();
    if (pass.length < 6) return notifyError("Minim 6 caractere.");
    setLoading(true);
    try {
      await adminService.changeUserPassword(user.id, pass);
      notifySuccess("Parola a fost actualizată!");
      onComplete();
    } catch (err) { notifyError("Eroare la schimbarea parolei."); }
    finally { setLoading(false); }
  };

  return (
    <form onSubmit={submit} className="space-y-4 pt-2">
      <Input label="Noua Parolă" type="text" value={pass} onChange={e => setPass(e.target.value)} required leftIcon={<Key className="w-4 h-4 text-slate-400"/>} />
      <div className="flex justify-end gap-3 pt-4"><Button type="button" variant="ghost" onClick={onCancel}>Anulează</Button><Button type="submit" variant="primary" isLoading={loading}>Schimbă</Button></div>
    </form>
  );
}

function FormDeleteUser({ user, onComplete, onCancel }: { user: AdminUserView | null, onComplete: () => void, onCancel: () => void }) {
  const [loading, setLoading] = useState(false);
  const { notifySuccess, notifyError } = useApp();

  const submit = async () => {
    if (!user) return;
    setLoading(true);
    try {
      await adminService.deleteUser(user.id);
      notifySuccess("Contul a fost șters!");
      onComplete();
    } catch (err: any) { notifyError(err.message || "Eroare la ștergere."); }
    finally { setLoading(false); }
  };

  return (
    <div className="flex flex-col items-center text-center pt-2">
      <div className="w-16 h-16 rounded-full bg-rose-100 flex items-center justify-center mb-5 border-4 border-rose-50"><AlertTriangle className="w-8 h-8 text-rose-600" /></div>
      <h3 className="text-2xl font-bold text-slate-950 mb-2">Ștergere Cont</h3>
      <p className="text-slate-600 mb-8">Sigur vrei să ștergi contul <strong>{user?.email}</strong>?</p>
      <div className="flex gap-3 w-full"><Button type="button" variant="outline" className="flex-1" onClick={onCancel}>Anulează</Button><Button type="button" variant="danger" className="flex-1" onClick={submit} isLoading={loading}>Șterge</Button></div>
    </div>
  );
}

function FormEditUser({ user, muns, provs, onComplete, onCancel }: { user: AdminUserView, muns: Municipality[], provs: Provider[], onComplete: () => void, onCancel: () => void }) {
  const [data, setData] = useState({ role: user.role || 'none', entityId: user.entityId || 'none' });
  const [loading, setLoading] = useState(false);
  const { notifySuccess, notifyError } = useApp();

  const submit = async (e: React.FormEvent) => {
    e.preventDefault();
    setLoading(true);
    try {
      await adminService.updateUserMapping(user.id, data.role === 'none' ? null : data.role as AppRole, data.entityId === 'none' ? null : data.entityId);
      notifySuccess("Asociere actualizată!");
      onComplete();
    } catch (err) { notifyError("Eroare la salvare."); }
    finally { setLoading(false); }
  };

  return (
    <form onSubmit={submit} className="space-y-4 pt-2">
      <Select label="Rol Sistem" value={data.role} onChange={e => setData({ role: e.target.value, entityId: 'none' })} options={[{ value: "none", label: "Fără Rol" }, { value: "admin", label: "Admin" }, { value: "primarie", label: "Primărie" }, { value: "furnizor", label: "Furnizor" }]} />
      {data.role !== 'admin' && data.role !== 'none' && (
        <Select label="Asociază Instituție" value={data.entityId} onChange={e => setData({ ...data, entityId: e.target.value })} options={[{ value: "none", label: "Alege..." }, ...(data.role === 'primarie' ? muns : provs).map(x => ({ value: x.id, label: x.name }))]} />
      )}
      <div className="flex justify-end gap-3 pt-4"><Button type="button" variant="ghost" onClick={onCancel}>Anulează</Button><Button type="submit" variant="primary" isLoading={loading}>Salvează</Button></div>
    </form>
  );
}

function FormAddMunicipality({ onComplete, onCancel }: { onComplete: () => void, onCancel: () => void }) {
  const [d, setD] = useState({ name: '', cui: '', contact_person: '', email: '', phone: '', locality: '', password: '' });
  const [loading, setLoading] = useState(false);
  const { notifySuccess, notifyError } = useApp();

  const submit = async (e: React.FormEvent) => {
    e.preventDefault();
    if (d.password.length < 6) return notifyError("Parola minim 6 caractere.");
    setLoading(true);
    try {
      const newMun = await createMunicipality({ name: d.name, cui: d.cui, contact_person: d.contact_person, email: d.email, phone: d.phone, locality: d.locality });
      await adminService.createUserAccountAndMap(d.email, d.password, 'primarie', newMun.id);
      notifySuccess("Primăria a fost creată!");
      onComplete();
    } catch (err: any) { notifyError(err.message || "Eroare."); }
    finally { setLoading(false); }
  };

  return (
    <form onSubmit={submit} className="space-y-4 pt-2">
      <Input label="Denumire Instituție" value={d.name} onChange={e => setD({...d, name: e.target.value})} required />
      <div className="grid grid-cols-2 gap-4"><Input label="CUI" value={d.cui} onChange={e => setD({...d, cui: e.target.value})} required /><Input label="Localitate" value={d.locality} onChange={e => setD({...d, locality: e.target.value})} required /></div>
      <Input label="Persoană Contact" value={d.contact_person} onChange={e => setD({...d, contact_person: e.target.value})} required />
      <Input label="Telefon Contact" value={d.phone} onChange={e => setD({...d, phone: e.target.value})} required />
      <div className="pt-4 border-t border-slate-100 mt-2 space-y-4">
        <Input label="Email Autentificare" type="email" value={d.email} onChange={e => setD({...d, email: e.target.value})} required />
        <Input label="Parolă Acces" type="text" value={d.password} onChange={e => setD({...d, password: e.target.value})} required />
      </div>
      <div className="flex justify-end gap-3 pt-4"><Button type="button" variant="ghost" onClick={onCancel}>Anulează</Button><Button type="submit" variant="primary" isLoading={loading}>Înregistrează</Button></div>
    </form>
  );
}

function FormEditMunicipality({ entity, onComplete, onCancel }: { entity: Municipality, onComplete: () => void, onCancel: () => void }) {
  const [d, setD] = useState({ name: entity.name, cui: entity.cui, locality: entity.locality, person: entity.contactPerson.name, phone: entity.contactPerson.phone });
  const [loading, setLoading] = useState(false);
  const { notifySuccess, notifyError } = useApp();

  const submit = async (e: React.FormEvent) => {
    e.preventDefault();
    setLoading(true);
    try {
      const { error } = await supabase.from('municipalities').update({ name: d.name, cui: d.cui, locality: d.locality, contact_person: d.person, phone: d.phone }).eq('id', entity.id);
      if (error) throw error;
      notifySuccess("Datele au fost salvate!");
      onComplete();
    } catch (err: any) { notifyError(err.message || "Eroare."); }
    finally { setLoading(false); }
  };

  return (
    <form onSubmit={submit} className="space-y-4 pt-2">
      <Input label="Denumire" value={d.name} onChange={e => setD({...d, name: e.target.value})} required />
      <div className="grid grid-cols-2 gap-4"><Input label="CUI" value={d.cui} onChange={e => setD({...d, cui: e.target.value})} required /><Input label="Localitate" value={d.locality} onChange={e => setD({...d, locality: e.target.value})} required /></div>
      <Input label="Persoană Contact" value={d.person} onChange={e => setD({...d, person: e.target.value})} required />
      <Input label="Telefon" value={d.phone} onChange={e => setD({...d, phone: e.target.value})} required />
      <div className="flex justify-end gap-3 pt-4"><Button type="button" variant="ghost" onClick={onCancel}>Anulează</Button><Button type="submit" variant="primary" isLoading={loading}>Salvează Modificări</Button></div>
    </form>
  );
}

