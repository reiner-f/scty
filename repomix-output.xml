    if (role === 'primarie') return municipalities.find(m => m.id === entityId)?.name || "Necunoscut";
    if (role === 'furnizor') return adminProviders.find(p => p.id === entityId)?.name || "Necunoscut";
    return "-";
  };

  const tabs = [
    { id: 'cereri', label: 'Monitorizare', icon: FileText },
